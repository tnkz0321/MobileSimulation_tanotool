<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>スマホ料金シミュレーター</title>
    <!-- 必要なライブラリの読み込み -->
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/framer-motion@10.16.4/dist/framer-motion.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap');
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-slate-50">
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useMemo, useEffect } = React;
        const { motion, AnimatePresence } = FramerMotion;

        // アイコンのセットアップ
        const Icon = ({ name, className }) => {
            useEffect(() => { lucide.createIcons(); }, []);
            return <i data-lucide={name} className={className}></i>;
        };

        function MobileFeeSimulator() {
            const CARRIER_OPTIONS = ['ドコモ', 'au', 'ソフトバンク', 'Y!mobile', 'UQmobile', 'ahamo'];
            
            const [selectedCarrierA, setSelectedCarrierA] = useState('ドコモ');
            const [selectedCarrierB, setSelectedCarrierB] = useState('au');
            const [devices, setDevices] = useState([{ deviceFeeA: 0, deviceFeeB: 0, planFeeA: 0, planFeeB: 0 }]);
            const [selectedEmail, setSelectedEmail] = useState('free');
            const [familyLines, setFamilyLines] = useState(1);
            const [hasInternetDiscount, setHasInternetDiscount] = useState('no');
            const [showResults, setShowResults] = useState(false);
            const [carrierSameError, setCarrierSameError] = useState(false);

            const nameA = selectedCarrierA;
            const nameB = selectedCarrierB;

            const MONTHS = 23;
            const deviceSavingsTotal = devices.reduce((sum, d) => sum + (d.deviceFeeA - d.deviceFeeB) * MONTHS, 0);
            const planSavingsTotal = devices.reduce((sum, d) => sum + (d.planFeeA - d.planFeeB) * MONTHS, 0);
            const grandTotalSavings = deviceSavingsTotal + planSavingsTotal;
            const remainingFamilyLines = familyLines - devices.length;

            const handleAddDevice = () => { if (devices.length < 6) setDevices([...devices, { deviceFeeA: 0, deviceFeeB: 0, planFeeA: 0, planFeeB: 0 }]); };
            const updateDevice = (index, field, value) => {
                const newDevices = [...devices];
                newDevices[index][field] = Number(value);
                setDevices(newDevices);
            };

            const handleCalculate = () => {
                if (nameA === nameB) { setCarrierSameError(true); return; }
                setCarrierSameError(false);
                setShowResults(true);
                window.scrollTo({ top: 0, behavior: 'smooth' });
            };

            const Stamp = ({ text, color = "red", isLarge = false }) => (
                <motion.div 
                    initial={{ scale: 2, opacity: 0, rotate: -20 }}
                    animate={{ scale: 1, opacity: 1, rotate: -12 }}
                    className={`absolute z-20 pointer-events-none border-4 font-black rounded-lg px-4 py-2 bg-white shadow-xl
                        ${isLarge ? 'text-2xl sm:text-4xl -top-10 -right-4 sm:-right-10' : 'text-xl -top-6 -right-6'}
                        ${color === 'red' ? 'border-red-500 text-red-500' : 'border-rose-600 text-rose-600'}`}
                >
                    {text}
                </motion.div>
            );

            return (
                <div className="min-h-screen pb-20">
                    <header className="bg-white border-b py-6 px-6 text-center">
                        <h1 className="text-2xl font-bold text-slate-900">スマホ料金比較シミュレーター</h1>
                    </header>

                    <main className="max-w-4xl mx-auto px-4 mt-8">
                        {!showResults ? (
                            <div className="space-y-6">
                                <section className="p-6 rounded-3xl bg-white border shadow-sm">
                                    <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                                        <div>
                                            <label className="text-xs font-bold text-indigo-600 mb-2 block">検討中キャリア</label>
                                            <select value={selectedCarrierA} onChange={(e) => setSelectedCarrierA(e.target.value)} className="w-full p-3 border rounded-xl bg-slate-50 appearance-none">
                                                {CARRIER_OPTIONS.map(opt => <option key={opt} value={opt}>{opt}</option>)}
                                            </select>
                                        </div>
                                        <div>
                                            <label className="text-xs font-bold text-indigo-600 mb-2 block">乗り換え後キャリア</label>
                                            <select value={selectedCarrierB} onChange={(e) => setSelectedCarrierB(e.target.value)} className="w-full p-3 border rounded-xl bg-slate-50 appearance-none">
                                                {CARRIER_OPTIONS.map(opt => <option key={opt} value={opt}>{opt}</option>)}
                                            </select>
                                        </div>
                                    </div>
                                    {carrierSameError && <p className="text-red-500 text-sm font-bold mt-4">※同じキャリアは選択できません</p>}
                                </section>

                                {devices.map((device, index) => (
                                    <div key={index} className="bg-white p-6 rounded-3xl border shadow-sm space-y-4">
                                        <span className="font-black text-indigo-600 bg-indigo-50 px-3 py-1 rounded-lg text-sm">{index + 1}台目</span>
                                        <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                            <div className="space-y-2">
                                                <label className="text-[10px] font-bold text-slate-400">月々の端末代</label>
                                                <input type="number" placeholder={`現在の${nameA}`} onChange={(e) => updateDevice(index, 'deviceFeeA', e.target.value)} className="w-full p-2 bg-slate-50 border rounded-lg" />
                                                <input type="number" placeholder={`乗り換え後の${nameB}`} onChange={(e) => updateDevice(index, 'deviceFeeB', e.target.value)} className="w-full p-2 border-indigo-200 border rounded-lg" />
                                            </div>
                                            <div className="space-y-2">
                                                <label className="text-[10px] font-bold text-slate-400">月々の通信料</label>
                                                <input type="number" placeholder={`現在の${nameA}`} onChange={(e) => updateDevice(index, 'planFeeA', e.target.value)} className="w-full p-2 bg-slate-50 border rounded-lg" />
                                                <input type="number" placeholder={`乗り換え後の${nameB}`} onChange={(e) => updateDevice(index, 'planFeeB', e.target.value)} className="w-full p-2 border-indigo-200 border rounded-lg" />
                                            </div>
                                        </div>
                                    </div>
                                ))}

                                <button onClick={handleAddDevice} className="w-full py-3 border-2 border-dashed border-slate-300 rounded-2xl text-slate-500 font-bold hover:bg-slate-100">+ 台数を追加</button>

                                <section className="bg-white p-6 rounded-3xl border shadow-sm grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div>
                                        <label className="text-xs font-bold text-slate-700 block mb-2">家族内の回線数</label>
                                        <input type="number" value={familyLines} onChange={(e) => setFamilyLines(Number(e.target.value))} className="w-full p-3 border rounded-xl" />
                                    </div>
                                    <div>
                                        <label className="text-xs font-bold text-slate-700 block mb-2">メール設定</label>
                                        <select value={selectedEmail} onChange={(e) => setSelectedEmail(e.target.value)} className="w-full p-3 border rounded-xl bg-white">
                                            <option value="free">フリーメール(0円)</option>
                                            <option value="carrier">キャリアメール継続利用</option>
                                        </select>
                                    </div>
                                </section>

                                <button onClick={handleCalculate} className="w-full py-5 bg-indigo-600 text-white rounded-2xl font-black text-xl shadow-lg">結果を表示する</button>
                            </div>
                        ) : (
                            <div className="space-y-8">
                                <div className="bg-slate-900 p-10 rounded-[40px] text-white relative shadow-2xl overflow-hidden">
                                    <h3 className="text-indigo-400 font-bold mb-2">23ヶ月（約2年）の合計お得額</h3>
                                    <div className="flex items-baseline gap-2">
                                        <span className="text-6xl font-black italic">¥{grandTotalSavings.toLocaleString()}</span>
                                        <span className="text-xl font-bold">お得！</span>
                                    </div>
                                    {grandTotalSavings >= 50000 ? <Stamp text="お乗り換えが超お得です" isLarge color="rose" /> : grandTotalSavings >= 1 && <Stamp text="お得" isLarge />}
                                </div>

                                <section className="bg-white p-6 rounded-3xl border shadow-sm">
                                    <h3 className="font-black mb-10 text-slate-800">4年間のスケジュールイメージ</h3>
                                    <div className="relative h-4 w-full bg-slate-100 rounded-full">
                                        <div className="absolute h-full w-1/2 bg-indigo-500 rounded-l-full"></div>
                                        <div className="absolute left-0 -top-8 text-[10px] font-bold text-slate-400">0ヶ月</div>
                                        <div className="absolute left-1/2 -top-8 -translate-x-1/2 text-[10px] font-bold text-indigo-600">23-24ヶ月</div>
                                        <div className="absolute right-0 -top-8 text-[10px] font-bold text-slate-400">48ヶ月</div>
                                        <div className="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
                                            <div className="w-1 h-12 bg-rose-500"></div>
                                            <div className="absolute -bottom-10 left-1/2 -translate-x-1/2 whitespace-nowrap bg-rose-500 text-white text-[10px] px-2 py-1 rounded">約2年後に返却</div>
                                        </div>
                                    </div>
                                    <p className="mt-14 text-[10px] text-slate-400 text-right">※キャリアや機種により最適な返却時期は異なります。</p>
                                </section>

                                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div className="bg-white p-6 rounded-3xl border text-center">
                                        <p className="text-slate-500 font-bold text-sm">端末代の節約</p>
                                        <p className="text-3xl font-black">¥{deviceSavingsTotal.toLocaleString()}</p>
                                    </div>
                                    <div className="bg-white p-6 rounded-3xl border text-center">
                                        <p className="text-slate-500 font-bold text-sm">通信料の節約</p>
                                        <p className="text-3xl font-black">¥{planSavingsTotal.toLocaleString()}</p>
                                    </div>
                                </div>

                                <div className="bg-indigo-50 p-6 rounded-3xl border border-indigo-100">
                                    <p className="font-bold text-indigo-900 mb-2">💡 スタッフからのアドバイス</p>
                                    <p className="text-sm text-indigo-700 leading-relaxed">
                                        {remainingFamilyLines < 3 
                                            ? `残るご家族の回線が${remainingFamilyLines}回線となるため、家族割の条件が変わる可能性があります。最適なプランを再計算いたします。`
                                            : `ご家族の回線は3回線以上維持されるため、家族割引は最大額で継続可能です！`}
                                    </p>
                                </div>

                                <button onClick={() => setShowResults(false)} className="w-full py-4 text-slate-400 font-bold hover:text-indigo-600 transition-colors">← 入力画面に戻る</button>
                            </div>
                        )}
                    </main>
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<MobileFeeSimulator />);
    </script>
</body>
</html>
